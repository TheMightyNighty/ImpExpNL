includes:
    - vendor/saschaegerer/phpstan-typo3/extension.neon

parameters:
    level: 6
    paths:
        - Classes
    excludePaths:
        analyse:
            - Tests/*
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Wertetypen generischer TYPO3-Record-Arrays (array<string,mixed>) werden nicht
        # erzwungen: hoher Churn, geringer Gewinn. Fachliche Strukturen sind über die
        # Domain-Value-Objects typisiert.
        - identifier: missingType.iterableValue
