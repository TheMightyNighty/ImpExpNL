{
    "name": "themightynighty/impexpnl",
    "type": "typo3-cms-extension",
    "description": "Enterprise CLI Exporter für TYPO3 v14",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Robert Schleiermacher",
            "email": "robert.schleiermacher@gmail.com",
            "role": "Entwicklung"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^14.0"
    },
    "require-dev": {
        "typo3/testing-framework": "^9.3",
        "typo3/cms-workspaces": "^14.0",
        "typo3/cms-redirects": "^14.0",
        "typo3/coding-standards": "^0.8",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0",
        "saschaegerer/phpstan-typo3": "^3.0",
        "ssch/typo3-rector": "^3.0",
        "opis/json-schema": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Robbi\\ImpExpNL\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Robbi\\ImpExpNL\\Tests\\": "Tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "scripts": {
        "ci:php:cs": "php-cs-fixer fix --dry-run --diff",
        "ci:php:cs-fix": "php-cs-fixer fix",
        "ci:php:stan": "phpstan analyse --no-progress --memory-limit=1G",
        "ci:php:rector": "rector process --dry-run",
        "ci:php:rector-fix": "rector process",
        "ci:test:unit": "phpunit -c phpunit.unit.xml",
        "ci:test:functional": "phpunit -c phpunit.functional.xml",
        "ci": [
            "@ci:php:cs",
            "@ci:php:stan",
            "@ci:test:unit"
        ]
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "imp_exp_nl",
            "version": "2.0.0",
            "Package": {
                "providesPackages": {}
            }
        }
    }
}
